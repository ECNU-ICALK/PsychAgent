五、成长经历
{% if client_info.growth_experiences -%}
{% for exp in client_info.growth_experiences -%}
  - {{ loop.index }}. {{ exp }}
{% endfor -%}
{% else -%}
- 未知
{% endif %}
六、存在性议题
{%- if client_info.existentialism_topic -%}
{%- for s in client_info.existentialism_topic -%}
  {% if s.theme is defined %}
  - 议题 {{ loop.index }}：
    - 议题主题：{{ s.theme | default('未知', true) }}
    - 相关描述：
    {%- if s.manifestations %}
      {%- for a in s.manifestations if a %}
      - {{ a }}
      {%- endfor %}
    {%- else %}
      暂无记录
    {% endif %}
    - 结果：
    {%- if s.outcomes %}
      {%- for a in s.outcomes if a %}
      - {{ a }}
      {%- endfor %}
    {%- else %}
      暂无记录
    {% endif %}
  {% else -%}
  - 议题 {{ loop.index }}：{{ s }}
  {% endif -%}
{% endfor -%}
{% else -%}
- 议题：未知
{% endif %}
七、接触模式
{%- if client_info.contact_model -%}
{%- for s in client_info.contact_model -%}
  {% if s.mode is defined %}
  - 模式 {{ loop.index }}：{{ s.mode | default('未知', true) }}
    - 定义：{{ s.definition | default('未知', true) }}
    - 具体表现：
    {%- if s.manifestations %}
      {%- for a in s.manifestations if a %}
      - {{ a }}
      {%- endfor %}
    {%- else %}
      暂无记录
    {% endif %}
  {% else -%}
  - 模式 {{ loop.index }}：{{ s }}
  {% endif -%}
{% endfor -%}
{% else -%}
- 模式：未知
{% endif -%}
{% else %}
(当前档案为空)
{% endif %}

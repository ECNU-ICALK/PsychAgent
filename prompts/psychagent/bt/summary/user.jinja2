【来访者背景信息】
{% if client_info -%}
{% set info = client_info.static_traits or {} -%}
{% macro line(label, value) -%}
- {{ label }}：{{ value | default('未知', true) }}
{%- endmacro -%}
一、基本信息
{{ line('姓名', info.name) }}
{{ line('年龄', info.age) }}
{{ line('性别', info.gender) }}
{{ line('职业', info.occupation) }}
{{ line('教育背景', info.educational_background) }}
{{ line('婚姻状况', info.marital_status) }}

二、家庭与社会关系
{{ line('家庭情况', info.family_status) }}
{{ line('社会关系状态', info.social_status) }}

三、身心状况
{{ line('既往病史', info.medical_history) }}

四、主诉与咨询目标
{{ line('主诉', client_info.main_problem) }}
{{ line('咨询主题', client_info.topic) }}
{{ line('核心诉求', client_info.core_demands) }}

五、成长经历
{% if client_info.growth_experiences -%}
{% for exp in client_info.growth_experiences -%}
  - {{ loop.index }}. {{ exp }}
{% endfor -%}
{% else -%}
- 未知
{% endif %}
六、靶行为
{%- if client_info.target_behavior -%}
{%- for s in client_info.target_behavior -%}
  {% if s.behavior is defined %}
  - 行为 {{ loop.index }}：
    - 行为名称：{{ s.behavior | default('未知', true) }}
    - 触发情境：
    {%- if s.antecedent %}
      {%- for a in s.antecedent if a %}
      - {{ a }}
      {%- endfor %}
    {%- else %}
      暂无记录
    {% endif %}
    - 核心原因：{{ s.core_reason | default('未知', true) }}
    - 行为功能：{{ s.function | default('未知', true) }}
    - 行为后果：{{ s.consequence | default('未知', true) }}
  {% else -%}
  - 行为 {{ loop.index }}：{{ s }}
  {% endif -%}
{% endfor -%}
{% else -%}
- 靶行为：未知
{% endif -%}
{% else %}
(当前档案为空)
{% endif %}

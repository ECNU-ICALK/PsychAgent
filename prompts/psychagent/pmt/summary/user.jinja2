【来访者背景信息】
{% if client_info -%}
{% set info = client_info.static_traits or {} -%}
{% macro line(label, value) -%}
- {{ label }}：{{ value | default('未知', true) }}
{%- endmacro -%}
一、基本信息
{{ line('姓名', info.name) }}
{{ line('年龄', info.age) }}
{{ line('性别', info.gender) }}
{{ line('职业', info.occupation) }}
{{ line('教育背景', info.educational_background) }}
{{ line('婚姻状况', info.marital_status) }}

二、家庭与社会关系
{{ line('家庭情况', info.family_status) }}
{{ line('社会关系状态', info.social_status) }}

三、身心状况
{{ line('既往病史', info.medical_history) }}

四、主诉与咨询目标
{{ line('主诉', client_info.main_problem) }}
{{ line('咨询主题', client_info.topic) }}
{{ line('核心诉求', client_info.core_demands) }}

五、成长经历
{% if client_info.growth_experiences -%}
{% for exp in client_info.growth_experiences -%}
  - {{ loop.index }}. {{ exp }}
{% endfor -%}
{% else -%}
- 未知
{% endif %}
六、例外事件
{%- if client_info.exception_events -%}
{%- for s in client_info.exception_events -%}
  {% if s.target_problem is defined %}
  - 事件{{ loop.index }}：
    - 针对问题：{{ s.target_problem | default('未知', true) }}
    - 独特结果：{{ s.unique_outcome | default('未知', true) }}
    - 发生原因：{{ s.reason | default('未知', true) }}
  {% else -%}
  - 事件{{ loop.index }}：{{ s }}
  {% endif -%}
{% endfor -%}
{% else -%}
- 事件：未知
{% endif %}
七、力场分析
{%- if client_info.force_field -%}
{% set s = client_info.force_field or {} %}
  - 积极力量：
  {%- if s.positive_force %}
    {%- for a in s.positive_force if a %}
    - {{ a }}
    {%- endfor %}
  {%- else %}
    暂无记录
  {% endif %}
  - 消极力量：
  {%- if s.negative_force %}
    {%- for a in s.negative_force if a %}
    - {{ a }}
    {%- endfor %}
  {%- else %}
    暂无记录
  {% endif %}
{% else -%}
- 力场：未知
{% endif -%}
{% else %}
(当前档案为空)
{% endif %}

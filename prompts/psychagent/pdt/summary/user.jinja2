五、成长经历
{% if client_info.growth_experiences -%}
{% for exp in client_info.growth_experiences -%}
  - {{ loop.index }}. {{ exp }}
{% endfor -%}
{% else -%}
- 未知
{% endif %}
六、核心冲突
{%- if client_info.core_conflict -%}
{% set s = client_info.core_conflict or {} %}
  - 深层欲望：{{ s.wish | default('未知', true) }}
  - 核心焦虑：{{ s.fear | default('未知', true) }}
  - 防御目标：
  {%- if s.defense_goal %}
    {%- for a in s.defense_goal if a %}
    - {{ a }}
    {%- endfor %}
  {%- else %}
    暂无记录
  {% endif %}
{% else -%}
- 冲突：未知
{% endif %}
七、客体关系
{%- if client_info.object_relations -%}
{%- for s in client_info.object_relations -%}
  {% if s.self_representation is defined %}
  - 关系 {{ loop.index }}：
    - 自体表象：{{ s.self_representation | default('未知', true) }}
    - 客体表象：{{ s.object_representation | default('未知', true) }}
    - 连接情感：{{ s.linking_affect | default('未知', true) }}
  {% else -%}
  - 关系 {{ loop.index }}：{{ s }}
  {% endif -%}
{% endfor -%}
{% else -%}
- 关系：未知
{% endif %}
八、防御机制
{%- if client_info.behavioral_response_patterns -%}
{%- for s in client_info.behavioral_response_patterns -%}
  {% if s.trigger_condition is defined %}
  - 机制 {{ loop.index }}：
    - 触发条件：{{ s.trigger_condition | default('未知', true) }}
    - 移情投射：{{ s.interpretation | default('未知', true) }}
    - 防御机制：{{ s.defense_mechanism | default('未知', true) }}
    - 响应指令：{{ s.response_instruction | default('未知', true) }}
  {% else -%}
  - 机制 {{ loop.index }}：{{ s }}
  {% endif -%}
{% endfor -%}
{% else -%}
- 机制：未知
{% endif -%}
{% else %}
(当前档案为空)
{% endif %}
